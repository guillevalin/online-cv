---
import { t, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const copy = t[lang];
---

<nav class="nav container">
  <a href={lang === 'en' ? '/' : '/es/'} class="nav-brand">GV</a>
  <div class="nav-links">
    <a href="#now">{lang === 'en' ? 'Now' : 'Ahora'}</a>
    <a href="#experience">{lang === 'en' ? 'Experience' : 'Experiencia'}</a>
    <a href="mailto:contact@guillermovalin.com">{lang === 'en' ? 'Contact' : 'Contacto'}</a>
    <a href={copy.nav.switchLangHref} class="lang-toggle">{copy.nav.switchLang}</a>
  </div>
</nav>
