---
import { t, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const n = t[lang].now;
---

<section id="now" class="container">
  <span class="section-label">{lang === 'en' ? '01 / Now' : '01 / Ahora'}</span>
  <h2 class="section-title">{n.title}</h2>
  <p class="section-subtitle">{n.subtitle}</p>

  <div class="proj-list">
    {n.items.map((item) => (
      <a class="proj-item" href={item.url} target="_blank" rel="noopener">
        <div class="proj-head">
          <h3 class="proj-title">{item.name}</h3>
          <div class="proj-meta">
            <span class="proj-tag">{item.tag}</span>
            <span>{item.year}</span>
          </div>
        </div>
        <p class="proj-copy">{item.copy}</p>
      </a>
    ))}
  </div>
</section>
