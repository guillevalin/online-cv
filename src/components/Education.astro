---
import { t, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const ed = t[lang].education;
---

<section id="education" class="container">
  <span class="section-label">{lang === 'en' ? '04 / Education' : '04 / Educación'}</span>
  <h2 class="section-title">{ed.title}</h2>

  {ed.items.map((item) => (
    <article class="edu-item">
      <h3 class="edu-degree">{item.degree}</h3>
      <p class="edu-institution">{item.institution}</p>
      <p class="edu-description">{item.description}</p>
    </article>
  ))}

  <div class="edu-languages">
    <span class="edu-languages-label">{ed.languages.label}</span>
    <div class="lang-items">
      {ed.languages.items.map((l) => <span class="lang-item">{l}</span>)}
    </div>
  </div>
</section>
